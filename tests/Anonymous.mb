type Operation = func(int, int) -> int

struct Point {
    x: int
    y: int
}

var add: Operation = (a, b) in a * b

func invoke(a, b, op: Operation) {
    print(op(a, b))
}

func invoke(point: Point) {
    invoke(...point, (a, b) in a + b)
}

invoke(1, 2, func(a, b) {
    return a + b
})

invoke(1, 2, (a, b) in a + b)
invoke(1, 2, mul)
invoke({x: 1, y: 2})
