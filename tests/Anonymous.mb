type Operation func(int, int) -> int

var mul = (a, b) -> a * b

struct Point {
    x: int
    y: int
}

func invoke(x: int, y: int, op: Operation) {
    var result = op(x, y)
    print(result)
}

invoke(1, 2, func(a, b) {
    return a + b
})

func invoke(point: Point) {
    invoke(...point, (a, b) -> a / b)
}

invoke((a, b) -> a + b)
invoke(1, 2, mul)
invoke({x: 1, y: 2})
