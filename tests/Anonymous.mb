type Operation = func(int, int): int

struct Point {
    x: int
    y: int
}

var mul: Operation = (a, b) => a * b

func invoke(a, b, op: Operation) {
    print(op(a, b))
}

func invoke(point: Point) {
    invoke(...point{x, y}, (a, b) => a / b)
}

invoke(1, 2, func(a, b) {
    return a + b
})

invoke(1, 2, (a, b) => a + b)
invoke(1, 2, mul)
invoke({x: 1, y: 2})
