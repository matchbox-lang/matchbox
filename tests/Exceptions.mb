class Exception {
    func what() {
        return "An exception occured."
    }
}

try {
    throw "An exception occured."
} catch (e: string) {
    print(e)
} finally {
    print("Execute finally.")
}

try {
    throw Exception()
} catch (e: Exception) {
    print(e.what())
} catch {
    print("An exception occured.")
}
