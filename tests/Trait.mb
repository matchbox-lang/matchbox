trait Hello {
    func printHello() {
        print("Hello")
    }
}

trait World {
    func printWorld() {
        print("World")
    }
}

class HelloWorld {
    use Hello
    use World
    
    func print() {
        printHello()
        print(" ")
        printWorld()
        print("!")
    }
}

var x = HelloWorld()
x.print()
