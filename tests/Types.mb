var i: int = 0              # Platform-specific signed integer
var i: uint = 0             # Platform-specific unsigned integer
var i: int8 = 0             # 8-bit signed integer
var i: int16 = 0            # 16-bit signed integer
var i: int32 = 0            # 32-bit signed integer
var i: int64 = 0            # 64-bit signed integer
var i: uint8 = 0            # 8-bit unsigned integer
var i: uint16 = 0           # 16-bit unsigned integer
var i: uint32 = 0           # 32-bit unsigned integer
var i: uint64 = 0           # 64-bit unsigned integer
var f: float = 0.0          # 32-bit floating-point number
var f: double = 0.0         # 64-bit floating-point number
var c: char = 'a'           # 32-bit Unicode character
var s: string = "abc"       # Sequence of Unicode characters
var b: bool = false         # Boolean value: true or false
